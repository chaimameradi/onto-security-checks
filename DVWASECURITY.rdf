    <!-- http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#Administrative_Countermeasure -->

    <owl:Class rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#Administrative_Countermeasure">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#contermeasure"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#AtRiskSystem -->

    <owl:Class rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#AtRiskSystem">
