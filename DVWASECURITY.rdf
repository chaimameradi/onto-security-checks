    </owl:Class>
    


    <!-- http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#HighCM -->

    <owl:Class rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#HighCM">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#contermeasure"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#hasEffectiveness"/>
                        <owl:hasValue>high</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#contermeasure"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#contermeasure"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#hasEffectiveness"/>
                        <owl:hasValue>high</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#hasEffectiveness"/>
                <owl:hasValue>high</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


