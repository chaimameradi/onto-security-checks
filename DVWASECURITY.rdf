    <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#contermeasure"/>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#hasEffectiveness"/>
                <owl:hasValue>high</owl:hasValue>
            </owl:Restriction>
        </owl:intersectionOf>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#HighCM"/>
    </owl:Class>
    <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/dvwaontologie#contermeasure"/>
            <owl:Restriction>
