                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#vulnerability"/>
            </owl:Restriction>
        </rdf:type>
        <pms:hasRisk rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#Session_Hijacking"/>
        <pms:hasRisk rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#System_Takeover"/>
        <pms:hasVulnerability rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#Command_Injection"/>
        <pms:hasVulnerability rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#Weak_Session"/>
        <pms:protectedby rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#AuditLogging"/>
        <pms:protectedby rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#TLSEncryption"/>
    </owl:NamedIndividual>
    


