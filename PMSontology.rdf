    <!-- http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#AccessControl -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#AccessControl">
        <rdf:type rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#countermeasure"/>
        <rdf:type>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#Reduces"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#countermeasure"/>
            </owl:Restriction>
        </rdf:type>
        <rdf:type>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/quicktech/ontologies/2025/10/PMSontology#Reduces"/>
